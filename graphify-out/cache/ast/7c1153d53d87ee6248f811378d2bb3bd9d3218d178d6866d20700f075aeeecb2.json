XTRACTED", "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L3", "weight": 1.0}, {"source": "home_theo_documents_theochinomona_tech_firecrawl_firecrawl_apps_api_src_services_worker_redis_ts", "target": "worker_redis_ensureredis", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L70", "weight": 1.0}, {"source": "home_theo_documents_theochinomona_tech_firecrawl_firecrawl_apps_api_src_services_worker_redis_ts", "target": "worker_redis_semaphorekeys", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L126", "weight": 1.0}, {"source": "home_theo_documents_theochinomona_tech_firecrawl_firecrawl_apps_api_src_services_worker_redis_ts", "target": "worker_redis_runscript", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L132", "weight": 1.0}, {"source": "worker_redis_runscript", "target": "worker_redis_ensureredis", "relation": "calls", "confidence": "EXTRACTED", "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L137", "weight": 1.0}], "raw_calls": [{"caller_nid": "worker_redis_ensureredis", "callee": "(async () => {\n      for (const [k, v] of Object.entries(luaScripts)) {\n        if (!scripts[k]) scripts[k] = {};\n        for (const [k2, v2] of Object.entries(v)) {\n          if (!scripts[k][k2]) {\n            const h = await redis.script(\"LOAD\", v2);\n            scripts[k][k2] = h as string;\n          }\n        }\n      }\n    })", "is_member_call": false, "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L75"}, {"caller_nid": "worker_redis_ensureredis", "callee": "catch", "is_member_call": true, "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L89"}, {"caller_nid": "worker_redis_ensureredis", "callee": "(async () => {\n    // Only call connect if in 'wait' state (not yet connected)\n    if (redis.status === \"wait\") {\n      await redis.connect();\n    } else if (redis.status === \"connecting\") {\n      // Already connecting, wait for it to complete\n      await new Promise<void>((resolve, reject) => {\n        const onReady = () => {\n          redis.off(\"error\", onError);\n          resolve();\n        };\n        const onError = (err: Error) => {\n          redis.off(\"ready\", onReady);\n          reject(err);\n        };\n        redis.once(\"ready\", onReady);\n        redis.once(\"error\", onError);\n      });\n    } else if (redis.status !== \"ready\") {\n      throw new Error(`Redis in unexpected state: ${redis.status}`);\n    }\n\n    for (const [k, v] of Object.entries(luaScripts)) {\n      scripts[k] = {};\n      for (const [k2, v2] of Object.entries(v)) {\n        const h = await redis.script(\"LOAD\", v2);\n        scripts[k][k2] = h as string;\n      }\n    }\n    logger.info(\"Redis connected and scripts loaded\");\n  })", "is_member_call": false, "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L89"}, {"caller_nid": "worker_redis_runscript", "callee": "evalsha", "is_member_call": true, "source_file": "/home/theo/Documents/Theochinomona.tech/firecrawl/firecrawl/apps/api/src/services/worker/redis.ts", "source_location": "L138"}]}