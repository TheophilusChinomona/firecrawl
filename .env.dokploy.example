# Firecrawl — Dokploy environment variables
# Copy these into Dokploy's environment panel for your Docker Compose app.
# Do NOT commit a filled-in version of this file.

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=firecrawl
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=firecrawl

# ─── LLM provider ──────────────────────────────────────────────────────────
# Using OpenRouter with OpenAI-compatible endpoint (same as k8s setup)
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

# ─── Firecrawl internals ───────────────────────────────────────────────────
BULL_AUTH_KEY=change-me-bull-auth-key
TEST_API_KEY=change-me-api-key
LOGGING_LEVEL=INFO

# ─── Worker tuning (defaults are fine for most servers) ───────────────────
NUM_WORKERS_PER_QUEUE=4
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5
BLOCK_MEDIA=true

# ─── Optional ──────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SEARXNG_ENDPOINT=http://searxng:8080   # if running a local SearXNG instance
