# =============================================================================
# Compose-level env contract for the self-hosted firecrawl + fire-enrich + MCP
# stack. Copy to `.env`, fill in the values, then `docker compose up -d`.
# `.env` is gitignored; this template is committed.
# =============================================================================

# --- Cloudflare Access -------------------------------------------------------
# Run `services/cf-access-setup.sh` (or click through Zero Trust → Access →
# Applications) to create the two apps + service token, then paste the AUDs
# and team subdomain here. The team subdomain is what comes before
# `.cloudflareaccess.com` (e.g. https://theochinomona.cloudflareaccess.com).
CF_ACCESS_TEAM=
CF_ACCESS_AUD_DASHBOARD=
CF_ACCESS_AUD_MCP=

# Comma-separated email allowlist for the dashboard.
OPERATOR_EMAILS=

# --- fire-enrich crypto ------------------------------------------------------
# Generate with: `openssl rand -base64 32` (run three times).
# Rotating these invalidates every existing principal token + admin cookie.
KEY_ENCRYPTION_KEY=
SERVER_PEPPER=
ADMIN_COOKIE_SECRET=
# Only used when OPS_AUTH_MODE != proxy. Generate: `openssl rand -base64 24`.
ADMIN_TOKEN=

# --- Traefik network --------------------------------------------------------
# Name of the external Docker network your Traefik instance routes from.
TRAEFIK_NETWORK=traefik

# --- Firecrawl backend -------------------------------------------------------
# fire-enrich tables share the firecrawl backend's nuq-postgres (different
# schema, no overlap). DATABASE_URL is built from POSTGRES_* below.
# Bull-Board + admin endpoint password. The dashboard reads this server-side
# to proxy queue/metrics endpoints — never exposed to the browser.
BULL_AUTH_KEY=

# Postgres for the firecrawl backend's nuq queue.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

USE_DB_AUTHENTICATION=false

# --- LLM provider for MCP enrich + research tools ----------------------------
# OpenRouter by default. To use OpenAI directly, leave LLM_BASE_URL blank.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_SMART=anthropic/claude-sonnet-4-6
LLM_MODEL_FAST=anthropic/claude-haiku-4-5

# Firecrawl backend's own LLM features (extract endpoint) read these.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Optional / tuning -------------------------------------------------------
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5

# Outbound proxy for scrapes (leave blank for direct egress).
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Slack webhook for alerts.
SLACK_WEBHOOK_URL=
