# --- Firecrawl backend ----------------------------------------------------
# Public URL the playground hits via FirecrawlApp SDK.
FIRECRAWL_API_KEY=fc-your-api-key-here
FIRECRAWL_API_URL=https://your-firecrawl-host.example.com

# Internal URL the ops dashboard hits server-side (compose-network hostname).
# Leave unset to fall back to FIRECRAWL_API_URL — fine for dev, weak for prod.
FIRECRAWL_INTERNAL_URL=http://api:3002

# Self-hosted admin secret. Required for the ops dashboard's
# /admin/{key}/redis-health, /admin/{key}/feng-check, /admin/{key}/metrics,
# /admin/{key}/queues (Bull-Board) probes. Held server-side; never reaches the browser.
BULL_AUTH_KEY=

# --- LLM (used by enrich + research tools) -------------------------------
OPENAI_API_KEY=sk-your-api-key-here

# --- MCP server ----------------------------------------------------------
# Internal URL of the firecrawl-mcp-server container (compose-network hostname).
# Required for the /admin/ops/mcp page. Leave blank to mark MCP as "not configured".
MCP_INTERNAL_URL=http://firecrawl-mcp:3000

# --- Auth ---------------------------------------------------------------
# How operator identity is established for /admin/* and /api/admin/*:
#   admin-token (default) — single shared HMAC cookie, login via ADMIN_TOKEN
#   proxy                 — trust X-Auth-User-Email from a known reverse proxy
#                           (Traefik forwardAuth → cf-access-verifier).
#                           The dashboard MUST be unreachable except through it.
#   either                — try the proxy header first, fall back to the cookie.
#                           Useful during a migration window or as break-glass.
OPS_AUTH_MODE=admin-token

# Optional comma-separated allowlist applied in proxy / either mode. Unset =
# any identity the upstream proxy authenticates is accepted.
OPERATOR_EMAILS=

# Required only when OPS_AUTH_MODE=admin-token (or =either with no proxy).
ADMIN_TOKEN=
ADMIN_COOKIE_SECRET=

# --- App ----------------------------------------------------------------
# Enable unlimited mode (optional). When true, removes all limits on rows,
# columns, and file size. Auto-enabled in development.
FIRE_ENRICH_UNLIMITED=true
NODE_ENV=development
