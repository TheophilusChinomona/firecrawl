# =============================================================================
# Production env contract for the self-hosted firecrawl stack.
# Copy this to .env (in the same dir as docker-compose.yaml), fill in values,
# then `docker compose up -d`. The install.sh script does this for you.
# =============================================================================

# --- Public hostnames --------------------------------------------------------
# DNS for these must point at this host's Traefik. Default to the upstream
# project's hosts; override for your own domain.
DASHBOARD_HOST=enrich.theochinomona.tech
MCP_HOST=crawl.theochinomona.tech

# --- Cloudflare Access -------------------------------------------------------
# Create two Access apps (one for the dashboard, one for /mcp) in Cloudflare
# Zero Trust → Access → Applications and paste the AUDs here. The team value
# is the subdomain before .cloudflareaccess.com.
CF_ACCESS_TEAM=
CF_ACCESS_AUD_DASHBOARD=
CF_ACCESS_AUD_MCP=

# Comma-separated email allowlist for the dashboard.
OPERATOR_EMAILS=

# --- fire-enrich crypto ------------------------------------------------------
# Generate each with: openssl rand -base64 32
# Rotating these invalidates every existing principal token + admin cookie.
KEY_ENCRYPTION_KEY=
SERVER_PEPPER=
ADMIN_COOKIE_SECRET=
# Only used when OPS_AUTH_MODE != proxy. Generate: openssl rand -base64 24
ADMIN_TOKEN=

# --- Traefik network --------------------------------------------------------
# Name of the external Docker network your Traefik instance routes from.
TRAEFIK_NETWORK=traefik

# --- Firecrawl backend -------------------------------------------------------
# Bull-Board admin password.
BULL_AUTH_KEY=

# Postgres for the queue + fire-enrich tables (shared instance).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

USE_DB_AUTHENTICATION=false

# --- LLM provider for MCP enrich + research tools ----------------------------
# OpenRouter by default. To use OpenAI directly, leave LLM_BASE_URL blank.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_SMART=anthropic/claude-sonnet-4-6
LLM_MODEL_FAST=anthropic/claude-haiku-4-5

# Firecrawl backend's own LLM features (extract endpoint, agent) read these.
# OPENAI_BASE_URL can also point at OpenRouter; MODEL_NAME overrides the
# hardcoded gpt-4o-mini/gpt-4.1-mini calls (e.g. google/gemini-2.5-flash-lite).
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=

# --- Notifications -----------------------------------------------------------
# Optional. Set either or both to receive Slack/Discord pings when callers
# pass `notifyOnCompletion: true` on a scrape, crawl, or batch-scrape.
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_DISCORD_WEBHOOK_URL=

# Generic alerts webhook (legacy upstream feature).
SLACK_WEBHOOK_URL=

# --- Optional / tuning -------------------------------------------------------
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5
LOGGING_LEVEL=info

# Outbound proxy for scrapes (leave blank for direct egress).
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional for self-hosted webhooks.
ALLOW_LOCAL_WEBHOOKS=true
BLOCK_MEDIA=
SELF_HOSTED_WEBHOOK_URL=

# Internal API key the dashboard + MCP use to call the API. Optional;
# leave blank if USE_DB_AUTHENTICATION=false.
FIRECRAWL_API_KEY=
TEST_API_KEY=
